# Chaos Engineering Dashboard Configuration

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# Server Configuration
SERVER_NAME=localhost
SERVER_PORT=5000

# Docker Configuration
DOCKER_COMPOSE_PATH=..
DOCKER_COMPOSE_FILE=docker-compose.yml

# Timeout Configuration (seconds)
DOCKER_COMMAND_TIMEOUT=30
HEALTH_CHECK_TIMEOUT=5
REQUEST_TIMEOUT=10

# Network Simulation
# Note: Real network delay requires root privileges and tc (traffic control)
USE_REAL_NETWORK_DELAY=false
TC_INTERFACE=eth0

# Logging
LOG_LEVEL=INFO
LOG_FILE=chaos_dashboard.log

# Security
CHAOS_MODE_DEFAULT=false
CONFIRM_DESTRUCTIVE_ACTIONS=true

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9091

# WebSocket
WEBSOCKET_ENABLED=false
WEBSOCKET_PING_INTERVAL=30
