# ----------------------------------------------------------------------------
# SECTION 8: IDEMPOTENCY (NEW FEATURE!)
# ----------------------------------------------------------------------------

### 8.1 First Transfer Request (Will Create)
# @name firstIdempotent
POST http://localhost:8082/api/transfers
Content-Type: application/json
X-Idempotency-Key: unique-key-123

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 100.00,
  "currency": "BRL"
}

> {%
    client.test("First idempotent request", function() {
        client.assert(response.status === 202, "Expected 202");
        client.global.set("firstTransferId", response.body.transferId);
        client.log("Created transfer: " + response.body.transferId);
    });
%}

### 8.2 Duplicate Request (Should Return Same Transfer)
# Same idempotency key - should return existing transfer
POST http://localhost:8082/api/transfers
Content-Type: application/json
X-Idempotency-Key: unique-key-123

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 100.00,
  "currency": "BRL"
}

> {%
    client.test("Duplicate idempotent request", function() {
        client.assert(response.status === 202, "Expected 202");
        client.assert(response.body.transferId === client.global.get("firstTransferId"), 
                      "Should return same transfer ID");
        client.log("✅ Idempotency working! Same transfer ID: " + response.body.transferId);
    });
%}

