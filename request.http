# ----------------------------------------------------------------------------
# SECTION 5: WORKFLOW CONTROL (PAUSE/RESUME/CANCEL)
# ----------------------------------------------------------------------------
# ⚠️ IMPORTANT: Execute these quickly after starting a transfer!
# The transfer has 10s delays in debit and credit steps.
# Total execution time: ~20 seconds without pauses.
# ----------------------------------------------------------------------------

### 5.1 Pause Transfer
# Run this within 10 seconds of starting a transfer!
POST http://localhost:8082/api/transfers/{{workflowId}}/pause

> {%
    client.test("Pause transfer", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
        client.log("⏸️ Transfer paused!");
    });
%}

### 5.2 Resume Transfer
# Resume the paused transfer
POST http://localhost:8082/api/transfers/{{workflowId}}/resume

> {%
    client.test("Resume transfer", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
        client.log("▶️ Transfer resumed!");
    });
%}

### 5.3 Cancel Transfer
POST http://localhost:8082/api/transfers/{{workflowId}}/cancel
Content-Type: application/json

{
  "action": "CANCEL",
  "reason": "User requested cancellation for testing"
}

> {%
    client.test("Cancel transfer", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
        client.log("❌ Transfer cancelled!");
    });
%}

### 5.4 Get Control Status
GET http://localhost:8082/api/transfers/{{workflowId}}/control-status

> {%
    client.test("Get control status", function() {
        client.assert(response.status === 200, "Expected 200");
        client.log("Paused: " + response.body.paused);
        client.log("Cancelled: " + response.body.cancelled);
        client.log("Last Action: " + response.body.lastControlAction);
    });
%}

# ----------------------------------------------------------------------------
# SECTION 6: BATCH OPERATIONS
# ----------------------------------------------------------------------------

### 6.1 Batch Pause Multiple Transfers
POST http://localhost:8082/api/transfers/batch/pause
Content-Type: application/json

[
  "{{workflowId}}",
  "{{largeWorkflowId}}"
]

> {%
    client.test("Batch pause", function() {
        client.assert(response.status === 200, "Expected 200");
        client.log("Successful: " + response.body.successful);
        client.log("Failed: " + response.body.failed);
    });
%}

### 6.2 Batch Cancel Multiple Transfers
POST http://localhost:8082/api/transfers/batch/cancel
Content-Type: application/json

{
  "workflowIds": [
    "{{workflowId}}",
    "{{largeWorkflowId}}"
  ],
  "reason": "Batch cancellation for maintenance"
}

> {%
    client.test("Batch cancel", function() {
        client.assert(response.status === 200, "Expected 200");
        client.log("Successful: " + response.body.successful);
        client.log("Failed: " + response.body.failed);
    });
%}

