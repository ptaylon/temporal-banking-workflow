# Temporal Banking Workflow - Complete API Testing Guide
# Version 2.0 - All Features Included
#
# ============================================================================
# QUICK START GUIDE
# ============================================================================
#
# This file contains comprehensive API examples for testing all features:
# ✅ Basic transfers
# ✅ Workflow control (pause/resume/cancel)
# ✅ Search attributes
# ✅ Configurable timers
# ✅ Idempotency
# ✅ Audit trail
# ✅ Feature flags
#
# HOW TO USE:
# 1. Open this file in IntelliJ IDEA or VS Code with REST Client extension
# 2. Start all services (account, transfer, validation, notification, audit)
# 3. Execute requests in order (they build on each other)
# 4. Variables are automatically captured and reused
#
# SERVICE PORTS:
# - Account Service: 8081
# - Transfer Service: 8082 (main service with all features)
# - Validation Service: 8087
# - Notification Service: 8086
# - Audit Service: 8085
#
# ============================================================================

# ----------------------------------------------------------------------------
# SECTION 1: ACCOUNT SETUP
# ----------------------------------------------------------------------------

### 1.1 Create Source Account - John Silva
# @name createSourceAccount
POST http://localhost:8081/api/accounts
Content-Type: application/json

{
  "accountNumber": "123456",
  "ownerName": "John Silva",
  "balance": 10000.00,
  "currency": "BRL"
}

> {%
    client.test("Source account created", function() {
        client.assert(response.status === 200 || response.status === 201, "Expected 200 or 201");
    });
%}

### 1.2 Create Destination Account - Maria Santos
# @name createDestAccount
POST http://localhost:8081/api/accounts
Content-Type: application/json

{
  "accountNumber": "789012",
  "ownerName": "Maria Santos",
  "balance": 5000.00,
  "currency": "BRL"
}

> {%
    client.test("Destination account created", function() {
        client.assert(response.status === 200 || response.status === 201, "Expected 200 or 201");
    });
%}

### 1.3 Get Source Account Details
GET http://localhost:8081/api/accounts/123456

### 1.4 Get Destination Account Details
GET http://localhost:8081/api/accounts/789012

# ----------------------------------------------------------------------------
# SECTION 2: BASIC TRANSFERS
# ----------------------------------------------------------------------------

### 2.1 Small Transfer (Fast Execution)
# This transfer completes quickly - good for basic testing
# @name smallTransfer
POST http://localhost:8082/api/transfers
Content-Type: application/json

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 50.00,
  "currency": "BRL"
}

> {%
    client.test("Transfer initiated", function() {
        client.assert(response.status === 202, "Expected 202");
        client.assert(response.body.status === "INITIATED", "Expected INITIATED status");
    });
    
    client.test("Capture workflowId", function() {
        client.global.set("workflowId", response.body.workflowId);
        client.global.set("transferId", response.body.transferId);
        client.log("Captured workflowId: " + response.body.workflowId);
        client.log("Captured transferId: " + response.body.transferId);
    });
%}

### 2.2 Large Transfer (Higher Priority)
# This transfer gets priority 3 (≥ $1,000)
# @name largeTransfer
POST http://localhost:8082/api/transfers
Content-Type: application/json

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 5000.00,
  "currency": "BRL"
}

> {%
    client.test("Large transfer initiated", function() {
        client.assert(response.status === 202, "Expected 202");
    });
    
    client.test("Capture large workflowId", function() {
        client.global.set("largeWorkflowId", response.body.workflowId);
        client.global.set("largeTransferId", response.body.transferId);
        client.log("Large transfer workflowId: " + response.body.workflowId);
    });
%}

### 2.3 VIP Transfer (Highest Priority - Level 5)
# This transfer gets priority 5 (≥ $100,000)
POST http://localhost:8082/api/transfers
Content-Type: application/json

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 150000.00,
  "currency": "BRL"
}

> {%
    client.test("VIP transfer initiated", function() {
        client.assert(response.status === 202, "Expected 202");
    });
%}

# ----------------------------------------------------------------------------
# SECTION 3: TRANSFERS WITH DELAYS (NEW FEATURE!)
# ----------------------------------------------------------------------------

### 3.1 Scheduled Transfer (30 Second Delay)
# Transfer will wait 30 seconds before starting
# You can cancel during this delay period
# @name delayedTransfer
POST http://localhost:8082/api/transfers
Content-Type: application/json

{
  "sourceAccountNumber": "123456",
  "destinationAccountNumber": "789012",
  "amount": 200.00,
  "currency": "BRL",
  "delayInSeconds": 30,
  "allowCancelDuringDelay": true
}

> {%
    client.test("Delayed transfer initiated", function() {
        client.assert(response.status === 202, "Expected 202");
    });
    
    client.test("Capture delayed workflowId", function() {
        client.global.set("delayedWorkflowId", response.body.workflowId);
        client.log("Delayed transfer workflowId: " + response.body.workflowId);
        client.log("⏰ Transfer will start in 30 seconds!");
    });
%}

### 3.2 Cancel Delayed Transfer (Execute Quickly!)
# Run this immediately after 3.1 to cancel during delay period
POST http://localhost:8082/api/transfers/{{delayedWorkflowId}}/cancel
Content-Type: application/json

{
  "action": "CANCEL",
  "reason": "Cancelled during delay period"
}

> {%
    client.test("Cancel during delay", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
        client.log("✅ Successfully cancelled during delay period!");
    });
%}

